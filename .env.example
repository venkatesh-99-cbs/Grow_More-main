DEBUG=False
SECRET_KEY=replace-with-a-long-random-secret-min-50-chars-use-secrets-module
ENVIRONMENT=production

# Render / Cloudflare hostnames
ALLOWED_HOSTS=your-render-service.onrender.com,www.yourdomain.com,yourdomain.com
CSRF_TRUSTED_ORIGINS=https://your-render-service.onrender.com,https://www.yourdomain.com,https://yourdomain.com

# Security settings for Render behind Cloudflare
SECURE_SSL_REDIRECT=True
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=True
SECURE_HSTS_PRELOAD=True

# Neon PostgreSQL
# Prefer DATABASE_URL in production. Render can read this directly from Neon.
DATABASE_URL=postgresql://USER:PASSWORD@HOST.neon.tech/DBNAME?sslmode=require

# Local SQLite fallback
DB_ENGINE=django.db.backends.sqlite3
DB_NAME=db.sqlite3

# Cloudinary media storage
USE_CLOUDINARY=True
CLOUDINARY_URL=cloudinary://API_KEY:API_SECRET@CLOUD_NAME

# Razorpay payment gateway
RAZORPAY_KEY_ID=rzp_live_xxxxx
RAZORPAY_KEY_SECRET=your_secret_key
RAZORPAY_CURRENCY=INR

# Google OAuth
GOOGLE_OAUTH_CLIENT_ID=xxxxx.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=your_client_secret

# Email
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=growmoreofficial.store@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=Grow More <noreply@yourdomain.com>

# Optional cache
REDIS_URL=redis://localhost:6379/0
