DEBUG=False
SECRET_KEY=replace-with-a-long-random-secret-min-50-chars-use-secrets-module
ALLOWED_HOSTS=your-render-host.onrender.com,your-railway-host.up.railway.app,localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=https://your-render-host.onrender.com,https://your-railway-host.up.railway.app

# Security Settings
SECURE_SSL_REDIRECT=True
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=True
SECURE_HSTS_PRELOAD=True

# Database Configuration
# SQLite (development)
DB_ENGINE=django.db.backends.sqlite3
DB_NAME=db.sqlite3

# PostgreSQL (production - uncomment and configure)
# DB_ENGINE=django.db.backends.postgresql
# DB_NAME=grow_more_db
# DB_USER=postgres
# DB_PASSWORD=your-password
# DB_HOST=localhost
# DB_PORT=5432

# Razorpay Payment Gateway
RAZORPAY_KEY_ID=rzp_test_xxxxx
RAZORPAY_KEY_SECRET=your_secret_key
RAZORPAY_CURRENCY=INR

# Google OAuth (optional, for "Sign in with Google")
GOOGLE_OAUTH_CLIENT_ID=xxxxx.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=your_client_secret

# Email Configuration (for order notifications)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=noreply@growmore.com

# AWS S3 Storage (optional, for media files)
USE_S3=False
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=ap-south-1

# Cache Configuration (optional)
CACHE_BACKEND=django.core.cache.backends.locmem.LocMemCache
REDIS_URL=redis://localhost:6379/0

# Deployment Platform
ENVIRONMENT=production

